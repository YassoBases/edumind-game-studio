{
  "name": "edumind-backend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "dev": "node --import tsx --watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/client": "^6.0.0",
    "fastify": "^5.8.5",
    "openai": "^5.0.0",
    "phaser": "4.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.60.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
