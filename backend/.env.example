# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://edumind:edumind@localhost:5432/edumind?schema=public

# Generation provider (Anthropic)
EDUMIND_GENERATION_PROVIDER=anthropic
EDUMIND_GENERATION_API_KEY=
EDUMIND_GENERATION_MODEL_PRIMARY=claude-sonnet-4-6
EDUMIND_GENERATION_MODEL_FAST=claude-haiku-4-5
EDUMIND_GENERATION_CACHE_TTL=1h

# Moderation provider (OpenAI)
EDUMIND_MODERATION_PROVIDER=openai
EDUMIND_MODERATION_API_KEY=
EDUMIND_MODERATION_MODEL=omni-moderation-latest

# Playability
PLAYABILITY_SAMPLE_RATE_PROD=0.2
PLAYWRIGHT_MAX_CONTEXTS=4

# Rate limiting
RATE_LIMIT_PER_STUDENT_PER_DAY=10
